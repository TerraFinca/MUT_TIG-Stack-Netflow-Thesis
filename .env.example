# Copy this file to .env and fill in real values BEFORE deployment.
# NEVER commit .env to git.

# Grafana SMTP (Gmail App Password — generate at https://myaccount.google.com/apppasswords)
GF_SMTP_USER=your-email@gmail.com
GF_SMTP_PASSWORD=your-gmail-app-password
GF_SMTP_FROM_ADDRESS=your-email@gmail.com

# Telegram Bot (talk to @BotFather to create a bot)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your-chat-id-or-group-id

# Email recipients for alerts (comma-separated)
ALERT_EMAIL=you@example.com

# Grafana web UI bind address (use 0.0.0.0 for all interfaces, or specific IP for restricted access)
GRAFANA_BIND_IP=0.0.0.0
